# GEMINI_API_KEY: Required for the Aegis Intelligence AI assistant.
# Without it the assistant returns a "not configured" message instead of erroring.
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Gemini model id used by the assistant (default: gemini-2.0-flash)
GEMINI_MODEL="gemini-2.0-flash"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# PORT: Backend API server port (default: 4000)
PORT=4000

# VITE_API_URL: Backend URL used by the frontend (default: http://localhost:4000)
VITE_API_URL="http://localhost:4000"

# AUTH_SECRET: HMAC secret for signing auth tokens (change in production)
AUTH_SECRET="change-me-in-production"
# SEED_PASSWORD: password for the seeded demo users (default: aegis2026)
SEED_PASSWORD="aegis2026"
# DB_PATH: SQLite database file path (default: server/data/aegis.db)
